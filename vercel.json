{
  "version": 2,
  "name": "research-reviewer-frontend",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://paperlens-naby.onrender.com"
  },
  "build": {
    "env": {
      "VITE_API_URL": "https://paperlens-naby.onrender.com"
    }
  }
}
