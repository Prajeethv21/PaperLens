# ============================================
# Environment Variables for AI Research Reviewer
# ============================================

# ============================================
# SECURITY - CRITICAL: Change all default values
# ============================================

# OpenAI API Key (required for LLM evaluation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret Key (CRITICAL: Change this in production!)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-strong-random-string

# Alternative: Use Groq for faster inference (optional)
# Get from: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here

# ============================================
# APPLICATION SETTINGS
# ============================================

APP_ENV=development
DEBUG=True

# Server Configuration
PORT=8000
HOST=0.0.0.0

# ============================================
# CORS SETTINGS
# ============================================

# Allowed origins (comma-separated)
# Production example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=.pdf

# Upload directory
UPLOAD_DIR=./uploads

# ============================================
# VECTOR STORE SETTINGS
# ============================================

CHROMA_PERSIST_DIR=./vector_store/chroma_data

# ============================================
# LLM SETTINGS
# ============================================

# Model selection (gpt-4, gpt-4-turbo, gpt-3.5-turbo)
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# ============================================
# RATE LIMITING
# ============================================

# Rate limits are configured in middleware/rate_limiter.py
# Default anonymous limits:
# - Upload: 5 requests per 15 minutes
# - Review: 10 requests per 15 minutes
# - Advanced: 3 requests per 15 minutes
# - Default: 30 requests per 5 minutes

# Default authenticated limits:
# - Upload: 20 requests per hour
# - Review: 50 requests per hour
# - Advanced: 15 requests per hour
# - Default: 100 requests per 5 minutes

# ============================================
# DATABASE (Optional - for future use)
# ============================================

# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=research_reviewer

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============================================
# SECURITY NOTES
# ============================================

# 1. Never commit .env file to version control
# 2. Use strong, randomly generated secrets
# 3. Rotate API keys regularly
# 4. In production, set APP_ENV=production and DEBUG=False
# 5. Use environment-specific .env files (.env.production, .env.development)
# 6. Consider using a secrets management service (AWS Secrets Manager, HashiCorp Vault)

